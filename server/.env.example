# Copy this file to server/.env and fill in as needed.
# server/.env is git-ignored and never committed.

# ── OMR Engine Configuration ───────────────────────────────────────────────

# Option A: Local CLI tools (recommended)
#
#   Install Oemer (Python, easiest):
#     pip install oemer
#   Then start the server:
#     npm run dev:api
#
# Override command names or provide full paths if not on PATH:
# OEMER_CLI=oemer
# AUDIVERIS_CLI=audiveris

# Option B: Remote OMR service
#   Point to any HTTP service accepting POST { image, mediaType } → { musicXmlString }
#   Example: a self-hosted Audiveris REST container
# OMR_ENDPOINT=http://localhost:8080/api/convert

# ── Server Port ────────────────────────────────────────────────────────────
# API_PORT=3001
